# Copy to .env for local development (never commit .env).
#
# Railway injects DATABASE_URL automatically when Postgres is linked.
# Local example (adjust user/password/db):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/curatify?schema=public

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-tunnel-or-host.example.com
SCOPES=read_products,read_inventory,write_products

# Set to false in production billing
SHOPIFY_BILLING_TEST=true
