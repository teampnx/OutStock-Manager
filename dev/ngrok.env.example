# Copy to dev/ngrok.env and fill in your authtoken.
#
# 1. Copy authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
# 2. Paste it into dev/ngrok.env as NGROK_AUTHTOKEN=...
#
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=turmoil-stingily-spinach.ngrok-free.dev
SHOPIFY_TUNNEL_PORT=3458
SHOPIFY_DEV_STORE=outstock-test-lionlx2x.myshopify.com

# Required after PostgreSQL migration — use local Postgres or Railway public URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/curatify?schema=public
